// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// --- USER MODELS --- //

model Birthday {
  userID String @id
  date   String
}

// --- GUILD MODELS --- //
model GuildConfig {
  guildID                 String @id
  eventIgnoredChannelIDs  String @default("[]") @db.Text
  rankedIgnoredChannelIDs String @default("[]") @db.Text
}

model Ban {
  date     String  @id
  guildID  String
  authorID String
  bannedID String
  reason   String  @db.Text
  unbanned Boolean @default(false)
}

model Rank {
  userID      String
  guildID     String
  xp          Int     @default(0)
  xpLevel     Int     @default(0)
  levelNotifs Boolean @default(true)
  credits     Int     @default(0)

  @@id([userID, guildID])
}

model Ticket {
  timeCreated     String  @id
  ticketPanelName String
  authorID        String
  channelID       String  @unique
  addedUsers      String  @default("[]") @db.Text
  open            Boolean @default(true)
}

model TicketPanel {
  timeCreated           String @id
  name                  String
  guildID               String
  categoryID            String
  moderatorRoleID       String
  panelEmbedJSON        String @db.Text
  ticketEmbedJSON       String @db.Text
  postedPanelMessageIDs String @default("[]") @db.Text

  @@unique([name, guildID])
}

model Warning {
  date     String @id
  guildID  String
  authorID String
  warnedID String
  reason   String @db.Text
}

model Notes {
  date      String @id
  authorID  String
  watchedID String
  guildID   String
  noteText  String @db.Text
}

model MemberStats {
  userID          String
  guildID         String
  messageCount    Int    @default(0)
  messagesPerHour String @db.Text

  @@id([userID, guildID])
}
