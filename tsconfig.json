{
	"compileOnSave": true,
	"compilerOptions": {
		"importHelpers": true,
		"incremental": true,
		"lib": [
			"ESNext",
			"DOM"
		],
		"module": "esnext",
		"moduleResolution": "node",
		"newLine": "lf",
		"noEmitHelpers": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"preserveConstEnums": true,
		"pretty": true,
		"removeComments": true,
		"resolveJsonModule": true,
		"strict": true,
		"target": "ESNext",
		"useDefineForClassFields": true,
		"outDir": "dist",
		"baseUrl": "src",
		"skipLibCheck": true,
		"esModuleInterop": true
	}
}