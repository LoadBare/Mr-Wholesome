{
	"compileOnSave": true,
	"compilerOptions": {
		"importHelpers": true,
		"incremental": true,
		"lib": [
			"ESNext",
			"DOM"
		],
		"newLine": "lf",
		"noEmitHelpers": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"preserveConstEnums": true,
		"pretty": true,
		"resolveJsonModule": true,
		"useDefineForClassFields": true,
		"outDir": "dist",
		"skipLibCheck": true,
		"types": ["node"],
		"rootDir": "./src"
	}
}